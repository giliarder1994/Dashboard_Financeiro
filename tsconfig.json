{
    "compilerOptions": {
      "target": "ES2022",
      "lib": ["ES2022"],

      "module": "NodeNext",
      "moduleResolution": "NodeNext",

      "rootDir": "src",
      "outDir": "dist",
      "sourceMap": true,

      "strict": true,
      "noImplicitAny": true,
      "strictNullChecks": true,

      "esModuleInterop": true,
      "allowSyntheticDefaultImports": true,

      "forceConsistentCasingInFileNames": true,
      "skipLibCheck": true
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist"]
  }